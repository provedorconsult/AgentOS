{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentos.local/schemas/task.schema.json",
  "title": "AgentOS Task",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "title", "goal", "agentGoal", "specRefs", "context", "files", "acceptanceCriteria", "verification", "evidence"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pending", "in-progress", "blocked", "verified", "done"] },
    "title": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "blocker": { "type": "string", "minLength": 1 },
    "review": { "type": "string", "minLength": 1 },
    "agentGoal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["needed"],
      "properties": {
        "needed": { "type": "boolean" },
        "draft": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "verificationSurface": { "type": "string", "minLength": 1 },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "boundaries": { "type": "array", "items": { "type": "string" } },
        "iterationPolicy": { "type": "string", "minLength": 1 },
        "blockedStopCondition": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "needed": { "const": true } }, "required": ["needed"] },
          "then": {
            "required": ["draft", "outcome", "verificationSurface", "constraints", "boundaries", "iterationPolicy", "blockedStopCondition"]
          }
        }
      ]
    },
    "specRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/rangeRef" } },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readOnly", "contracts"],
      "properties": {
        "readOnly": { "type": "array", "items": { "$ref": "#/$defs/rangeRef" } },
        "contracts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "action": { "enum": ["create", "modify", "delete"] }
        }
      }
    },
    "acceptanceCriteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": { "commands": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "command", "exitCode", "status", "result"],
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "exitCode": { "type": "integer" },
          "status": { "enum": ["passed", "failed", "blocked", "not-run"] },
          "result": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "rangeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "range"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "range": { "type": "string", "pattern": "^[1-9][0-9]*-[1-9][0-9]*$" }
      }
    }
  }
}
