{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentos.local/schemas/agentos-config.schema.json",
  "title": "AgentOS Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "agentos", "layers", "skills", "goals", "context", "verification", "extensions", "packs", "adapters"],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "status"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "status": { "enum": ["active", "maintenance", "archived"] }
      }
    },
    "agentos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "mode", "spec_engine", "default_workflow"],
      "properties": {
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
        "mode": { "type": "string", "minLength": 1 },
        "spec_engine": { "const": "specpilot" },
        "default_workflow": { "type": "string", "minLength": 1 }
      }
    },
    "layers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agents"],
      "properties": {
        "agents": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "root", "format"],
      "properties": {
        "enabled": { "type": "boolean" },
        "root": { "type": "string", "minLength": 1 },
        "format": { "const": "markdown" }
      }
    },
    "goals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "root", "hierarchy"],
      "properties": {
        "enabled": { "type": "boolean" },
        "root": { "type": "string", "minLength": 1 },
        "hierarchy": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_spec_range_lines", "max_readonly_files_per_task", "max_acceptance_criteria_per_task", "forbidden_dirs"],
      "properties": {
        "max_spec_range_lines": { "type": "integer", "minimum": 1 },
        "max_readonly_files_per_task": { "type": "integer", "minimum": 1 },
        "max_acceptance_criteria_per_task": { "type": "integer", "minimum": 1 },
        "forbidden_dirs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["require_exit_code", "require_evidence_per_criterion", "require_review_file", "require_no_secrets_scan"],
      "properties": {
        "require_exit_code": { "const": true },
        "require_evidence_per_criterion": { "const": true },
        "require_review_file": { "const": true },
        "require_no_secrets_scan": { "const": true }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status"],
        "properties": {
          "status": { "enum": ["planned", "active", "disabled"] }
        }
      }
    },
    "packs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "available"],
      "properties": {
        "enabled": { "type": "boolean" },
        "available": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "adapters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default", "available"],
      "properties": {
        "default": { "type": "string", "minLength": 1 },
        "available": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
